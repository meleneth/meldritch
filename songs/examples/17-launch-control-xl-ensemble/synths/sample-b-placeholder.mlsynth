[meldritch]
kind = "synth"
version = 1

[synth]
id = "sample-b-placeholder"
polyphony = 1

[[inputs]]
id = "pitch"
type = "pitch"

[[inputs]]
id = "gate"
type = "gate"

[[modules]]
id = "osc"
type = "oscillator"
waveform = "sine"

[[modules]]
id = "env"
type = "adsr"
attack = 0.02
decay = 0.24
sustain = 0.45
release = 0.22

[[modules]]
id = "amp"
type = "vca"

[[modules]]
id = "filter"
type = "low_pass"
cutoff_hz = 2800.0
resonance = 0.5

[[modules]]
id = "out"
type = "audio_output"
channels = 1

[[cables]]
from = "input.pitch"
to = "osc.pitch"

[[cables]]
from = "input.gate"
to = "env.gate"

[[cables]]
from = "osc.audio"
to = "amp.audio"

[[cables]]
from = "env.control"
to = "amp.level"

[[cables]]
from = "amp.audio"
to = "filter.audio"

[[cables]]
from = "filter.audio"
to = "out.audio"

