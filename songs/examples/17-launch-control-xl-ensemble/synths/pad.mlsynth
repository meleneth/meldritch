[meldritch]
kind = "synth"
version = 1

[synth]
id = "pad"
polyphony = 4

[[inputs]]
id = "pitch"
type = "pitch"

[[inputs]]
id = "gate"
type = "gate"

[[modules]]
id = "osc"
type = "oscillator"
waveform = "saw"

[[modules]]
id = "env"
type = "adsr"
attack = 0.08
decay = 0.45
sustain = 0.75
release = 0.8

[[modules]]
id = "amp"
type = "vca"

[[modules]]
id = "filter"
type = "low_pass"
cutoff_hz = 2100.0
resonance = 0.18

[[modules]]
id = "out"
type = "audio_output"
channels = 1

[[cables]]
from = "input.pitch"
to = "osc.pitch"

[[cables]]
from = "input.gate"
to = "env.gate"

[[cables]]
from = "osc.audio"
to = "amp.audio"

[[cables]]
from = "env.control"
to = "amp.level"

[[cables]]
from = "amp.audio"
to = "filter.audio"

[[cables]]
from = "filter.audio"
to = "out.audio"
