[meldritch]
kind = "pattern"
version = 1

[pattern]
id = "echo-motion"
type = "parameters"
length = "1 bar"
loop = true

[[lanes]]
target = "dsp:echo/delay.feedback"
interpolation = "step"

[[lanes.points]]
at = "1:1:0"
value = 0.15

[[lanes.points]]
at = "1:2:0"
value = 0.35

[[lanes.points]]
at = "1:3:0"
value = 0.55

[[lanes.points]]
at = "1:4:0"
value = 0.25
